---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/sections/Hero.astro';
import Stakes from '../components/sections/Stakes.astro';
import Changes from '../components/sections/Changes.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Vektor10 — The First ChatGPT™ Commerce Agency"
  themeColor="#A5B5C3"
  rootBackground="linear-gradient(to bottom, #A5B5C3, #A5B5C3 50%, #2E926C 50%)"
>
  <Nav />
  <Hero />
  <Stakes />
  <Changes />

  <section class="flex flex-col items-center gap-4 bg-bone px-6 py-32 text-center">
    <p class="eyebrow text-teal">&lt; SECTIONS LANDING DAILY &gt;</p>
    <p class="max-w-md font-mono text-body leading-[26px] text-ink/65">
      How It Works, The Plan In Action, the offer, and the FAQ are being ported from the design canvas now.
    </p>
  </section>

  <Footer />
</Base>
