---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const features = [
  {
    eyebrow: 'SHARE OF SHELF',
    title: 'Know your category share — for real.',
    body: 'Your share of ChatGPT\u2122 recommendations, broken down by query type: discovery, comparison, price-filtered, use-case. Trended over time. Benchmarked against every competitor. With confidence intervals, not guesses.',
    image: '/trace-competitive.png',
    alt: 'Trace competitive share dashboard showing brand ranking and topic coverage',
  },
  {
    eyebrow: 'PRODUCT-LEVEL VISIBILITY',
    title: 'Every SKU. Every query. Every day.',
    body: 'Which products get recommended, in what position, at what price, from which retailer. Which hero products are invisible. Which ones stopped showing up last week.',
    image: '/trace-triage.png',
    alt: 'Trace product triage view showing SKU-level visibility and opportunity ranking',
  },
  {
    eyebrow: 'CITATION AUTHORITY',
    title: 'The sources deciding your category, mapped.',
    body: 'Trace maps every source ChatGPT\u2122 pulls from when it recommends products in your space — editorial, YouTube, Reddit, retailers, your own pages. You see where you are cited, where you are absent, and which gaps matter most.',
    image: '/trace-authority.png',
    alt: 'Trace citation authority map showing source layers and gap indicators',
  },
  {
    eyebrow: 'PRICE & FEED ACCURACY',
    title: 'Wrong price? We catch it the day it happens.',
    body: 'ChatGPT\u2122 showed a client\'s product at $54.99. Actual price: $28.23. That kind of gap kills position. Trace monitors price accuracy, feed health, merchant attribution, and buy-link integrity across your full catalog.',
    image: '/trace-alerts.png',
    alt: 'Trace alerts feed showing price drift detection and feed readiness',
  },
  {
    eyebrow: 'THE LOST SHELF',
    title: 'How much is it costing you?',
    body: 'Plug in your AOV and conversion rate. Trace models three scenarios and tells you, in dollars, the gap between your current share and your fair share.',
    image: '/trace-lost-shelf.png',
    alt: 'Trace lost shelf calculator showing revenue gap scenarios',
  },
];

const cadence = [
  {
    label: 'Weekly',
    desc: 'What moved, what broke, what we shipped. In your inbox.',
  },
  {
    label: 'Monthly',
    desc: 'Category share, engine by engine. Board-ready.',
  },
  {
    label: 'Real-time',
    desc: 'Drift alerts. You will see them. We are already on it.',
  },
];
---

<Base title="Powered by Trace — Vektor10">
  <Nav />

  {/* ── Hero ── */}
  <section class="flex flex-col items-center bg-bone px-6 pb-10 pt-24 sm:px-[60px] sm:pt-[150px]">
    <div class="flex w-full max-w-[1000px] flex-col items-center gap-6 text-center">
      <p class="eyebrow text-teal">&lt; POWERED BY TRACE &gt;</p>
      <h1 class="max-w-[800px] font-display text-[26px] leading-[108%] tracking-[-0.02em] text-ink sm:text-headline">
        See exactly how your products show up in ChatGPT&trade;.
      </h1>
      <p class="max-w-[680px] font-mono text-body font-medium leading-[26px] text-ink/65">
        Trace tracks every product you sell against what ChatGPT&trade; actually shows shoppers — at the SKU level, every day. Not brand mentions. Products, prices, and the buy link.
      </p>
      <a href="/contact" class="btn-hard mt-2 uppercase tracking-[0.08em]">Get Your Free Plan</a>
    </div>
  </section>

  {/* ── Hero screenshot ── */}
  <section class="flex flex-col items-center bg-bone px-4 pb-20 pt-6 sm:px-10">
    <div class="w-full max-w-[1000px]">
      <img
        src="/trace-dashboard.png"
        alt="Trace dashboard overview showing portfolio health, SKU coverage, and open alerts"
        width="1920"
        height="1080"
        loading="eager"
        decoding="async"
        class="w-full rounded-card border-2 border-ink bg-white object-cover [box-shadow:-2px_4px_0_0_#141413]"
      />
    </div>
  </section>

  {/* ── Feature sections — alternating bone / ink ── */}
  {features.map((feat, i) => {
    const isDark = i % 2 === 0;
    return isDark ? (
      <section class="relative flex flex-col items-center overflow-clip bg-ink px-6 py-20 sm:px-[60px] sm:py-28">
        <svg class="absolute inset-0 h-full w-full" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <defs>
            <pattern id={`grid-${i}`} width="20" height="20" patternUnits="userSpaceOnUse">
              <path d="M0.5 0 V20 M0 0.5 H20" fill="none" stroke="#403D38" shape-rendering="crispEdges" />
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill={`url(#grid-${i})`} />
        </svg>
        <div class="relative flex w-full max-w-[1000px] flex-col gap-10" data-stagger>
          <div class="flex flex-col gap-[5px]" data-reveal>
            <p class="eyebrow text-teal">&lt; {feat.eyebrow} &gt;</p>
            <h2 class="max-w-[600px] font-display text-[24px] leading-[112%] tracking-[-0.02em] text-bone sm:text-headline">
              {feat.title}
            </h2>
            <p class="mt-3 max-w-[580px] font-mono text-body font-medium leading-[26px] text-bone-muted">
              {feat.body}
            </p>
          </div>
          <div data-reveal>
            <img
              src={feat.image}
              alt={feat.alt}
              width="1920"
              height="1080"
              loading="lazy"
              decoding="async"
              class="w-full rounded-card border border-dark-hairline bg-ink-panel object-cover"
            />
          </div>
        </div>
      </section>
    ) : (
      <section class="flex flex-col items-center bg-bone px-6 py-20 sm:px-[60px] sm:py-28">
        <div class="flex w-full max-w-[1000px] flex-col gap-10" data-stagger>
          <div class="flex flex-col gap-[5px]" data-reveal>
            <p class="eyebrow text-teal">&lt; {feat.eyebrow} &gt;</p>
            <h2 class="max-w-[600px] font-display text-[24px] leading-[112%] tracking-[-0.02em] text-ink sm:text-headline">
              {feat.title}
            </h2>
            <p class="mt-3 max-w-[580px] font-mono text-body font-medium leading-[26px] text-ink/65">
              {feat.body}
            </p>
          </div>
          <div data-reveal>
            <img
              src={feat.image}
              alt={feat.alt}
              width="1920"
              height="1080"
              loading="lazy"
              decoding="async"
              class="w-full rounded-card border-2 border-ink bg-white object-cover [box-shadow:-2px_4px_0_0_#141413]"
            />
          </div>
        </div>
      </section>
    );
  })}

  {/* ── PDP view ── */}
  <section class="relative flex flex-col items-center overflow-clip bg-ink px-6 py-20 sm:px-[60px] sm:py-28">
    <svg class="absolute inset-0 h-full w-full" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <pattern id="grid-pdp" width="20" height="20" patternUnits="userSpaceOnUse">
          <path d="M0.5 0 V20 M0 0.5 H20" fill="none" stroke="#403D38" shape-rendering="crispEdges" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid-pdp)" />
    </svg>
    <div class="relative flex w-full max-w-[1000px] flex-col gap-10" data-stagger>
      <div class="flex flex-col gap-[5px]" data-reveal>
        <p class="eyebrow text-teal">&lt; PRODUCT DETAIL &gt;</p>
        <h2 class="max-w-[600px] font-display text-[24px] leading-[112%] tracking-[-0.02em] text-bone sm:text-headline">
          Drill into any SKU. See everything the AI sees.
        </h2>
        <p class="mt-3 max-w-[580px] font-mono text-body font-medium leading-[26px] text-bone-muted">
          Position history, price accuracy, source citations, query coverage, and competitive context — all on one screen, updated daily.
        </p>
      </div>
      <div data-reveal>
        <img
          src="/trace-pdp.png"
          alt="Trace product detail page showing position history, price accuracy, and citation sources for a single SKU"
          width="1920"
          height="1080"
          loading="lazy"
          decoding="async"
          class="w-full rounded-card border border-dark-hairline bg-ink-panel object-cover"
        />
      </div>
    </div>
  </section>

  {/* ── Alerts, Not Reports ── */}
  <section class="flex flex-col items-center bg-bone px-6 py-20 sm:px-[60px] sm:py-28">
    <div class="flex w-full max-w-[1000px] flex-col gap-10" data-stagger>
      <div
        class="flex flex-col gap-[5px] rounded-card border-2 border-ink bg-ink-panel px-8 py-[30px] sm:px-[50px] [box-shadow:inset_-2px_4px_3px_#FFFFFF33,-2px_4px_0_0_#141413]"
        data-reveal
      >
        <p class="eyebrow text-teal">&lt; ALERTS, NOT REPORTS &gt;</p>
        <h2 class="font-display text-[24px] leading-[112%] tracking-[-0.02em] text-bone sm:text-headline">
          We act on it before you read it.
        </h2>
        <p class="mt-3 max-w-[580px] font-mono text-body font-medium leading-[26px] text-bone-deep/65">
          Hero product went invisible. Price drifted 20%. Competitor entered your recommendation set. Trace surfaces it. Our team fixes it. You see it in your weekly update.
        </p>
      </div>

      {/* Cadence cards */}
      <div class="flex w-full flex-col gap-5 lg:flex-row" data-reveal>
        {cadence.map(({ label, desc }) => (
          <article class="flex min-w-0 flex-1 flex-col gap-3 rounded-card border-2 border-ink bg-bone-deep px-8 py-8 [box-shadow:inset_-2px_4px_3px_#F0EEE5,-2px_4px_0_0_#141413]">
            <h3 class="font-display text-[22px] leading-[115%] tracking-[-0.01em] text-ink">{label}</h3>
            <p class="font-mono text-body font-medium leading-[165%] text-ink/65">{desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ── Closing CTA ── */}
  <section class="flex flex-col items-center bg-bone-deep px-6 py-20 sm:px-[60px] sm:py-28">
    <div class="flex w-full max-w-[700px] flex-col items-center gap-6 text-center">
      <h2 class="font-display text-[24px] leading-[112%] tracking-[-0.02em] text-ink sm:text-headline">
        Your competitors are already on ChatGPT&trade;&rsquo;s shelf. See where you stand.
      </h2>
      <a href="/contact" class="btn-hard uppercase tracking-[0.08em]">Get Your Free Plan</a>
    </div>
  </section>

  <Footer />
</Base>
