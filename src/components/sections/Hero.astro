---
import EmailForm from '../EmailForm.astro';

// Canvas-true hero: photo ground, glass card (white 65% + blur 8 + grain),
// typewriter cycling word (spec #1, Trey's verdict: backspace + retype, block caret),
// card holds screen position on scroll and fades before the seam (spec #4).
---

<section id="hero" class="relative -mt-[66px] h-[100svh] max-h-[900px] min-h-[600px] w-full overflow-clip sm:-mt-[96px] sm:h-[900px] sm:max-h-none" data-hero>
  <div
    class="absolute inset-0 bg-cover bg-center"
    style="background-image: url('/hero-bg.jpg');"
    role="img"
    aria-label="Retro-analog consumer products in a dreamlike studio scene"
  >
  </div>

  <div class="relative flex h-full items-center justify-center px-5 pb-[30px] sm:px-10">
    <div
      data-hero-card
      class="relative flex w-fit max-w-[1080px] flex-col items-center justify-center gap-5 rounded-glass border-2 border-ink bg-white/65 px-6 py-8 backdrop-blur-[8px] backdrop-saturate-[1.2] sm:px-[65px] sm:py-[50px] [box-shadow:inset_-2px_4px_3px_#FFFFFF,-2px_2px_0_0_#141413]"
    >
      <div
        class="pointer-events-none absolute inset-0 rounded-[13px] opacity-35 mix-blend-soft-light [background-image:url('/noise.png')] [background-size:200px_200px] [background-repeat:repeat]"
        aria-hidden="true"
      >
      </div>

      <div class="relative flex items-center gap-2 rounded-full bg-white pr-3">
        <span class="grid h-[25px] w-[35px] shrink-0 place-items-center rounded-full bg-ink">
          <img src="/v5.png" alt="" class="h-3 w-auto" />
        </span>
        <span class="font-mono text-body font-medium leading-[18px] text-ink">A VantaFive Agency</span>
      </div>

      {/* Below lg the headline snaps to a fixed 4-line layout so the cycling
          word is never orphaned or stranded mid-sentence (Trey's mockup). */}
      <h1 class="relative text-center font-display text-[26px] leading-[112%] tracking-[-0.01em] text-ink sm:text-display">
        <span>When shoppers ask</span>
        <br class="lg:hidden" />
        <span>ChatGPT™ which&nbsp;</span><span data-chip-slot class="inline-flex h-[1.12em] justify-start align-baseline"><span data-chip class="flex h-full items-stretch gap-0.5 bg-white px-2"><span data-cycling-word class="whitespace-pre leading-[1.12em] text-teal">sofa</span><span data-caret class="w-0.5 shrink-0 self-stretch bg-ink"></span></span></span>
        <br />
        <span>to buy, is your product</span>
        <br class="lg:hidden" />
        <span>the one it picks?</span>
        <span data-word-measure class="invisible absolute -z-10 whitespace-pre" aria-hidden="true"></span>
      </h1>

      <p class="relative max-w-[682px] text-center font-mono text-body font-medium leading-[165%] text-ink/65">
        ChatGPT™ is becoming a new product shelf. Vektor10 makes sure your products are visible, accurate, and
        recommended.
      </p>

      <EmailForm class="relative max-w-[546px]" />

      <p class="relative text-center font-display text-body leading-[18px] tracking-[0.02em] text-ink">
        The 1st Full-Suite ChatGPT™ Commerce Agency
      </p>
    </div>
  </div>
</section>

<style>
  [data-caret] {
    animation: caret-blink 1s steps(1) infinite;
  }
  [data-caret].typing {
    animation: none;
    opacity: 1;
  }
  @keyframes caret-blink {
    50% {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    [data-caret] {
      animation: none;
    }
  }
</style>

<script>
  // Typewriter cycling word: hold → backspace → type next (Trey's spec #1 verdict).
  const WORDS = ['sofa', 'shoe', 'luggage', 'games'];
  const HOLD = 2200;
  const BACKSPACE_MS = 55;
  const TYPE_MS = 95;

  const word = document.querySelector<HTMLElement>('[data-cycling-word]');
  const caret = document.querySelector<HTMLElement>('[data-caret]');
  const slot = document.querySelector<HTMLElement>('[data-chip-slot]');
  const measurer = document.querySelector<HTMLElement>('[data-word-measure]');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (word && caret && slot && measurer && !reduced) {
    // ZWSP keeps the chip's line box (and the caret + padding) alive when the
    // word is fully backspaced — the chip never collapses or blinks away.
    const ZWSP = '​';
    const setWord = (text: string) => {
      word.textContent = text || ZWSP;
    };

    // The reservation frame holds the longest word's width so the fit-content
    // hero card never breathes as words change. The chip inside hugs freely.
    const CHROME = 16 /* px-2 */ + 2 /* caret */ + 2 /* gap */;
    const sizeSlot = () => {
      const longest = WORDS.reduce((a, b) => (b.length > a.length ? b : a));
      measurer.textContent = longest;
      slot.style.width = `${measurer.offsetWidth + CHROME}px`;
    };
    document.fonts.ready.then(sizeSlot);
    let resizeT: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeT);
      resizeT = setTimeout(sizeSlot, 150);
    });

    let i = 0;
    const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));

    (async () => {
      for (;;) {
        await sleep(HOLD);
        const current = WORDS[i];
        i = (i + 1) % WORDS.length;
        const next = WORDS[i];

        caret.classList.add('typing');
        for (let n = current.length; n >= 0; n--) {
          setWord(current.slice(0, n));
          await sleep(BACKSPACE_MS);
        }
        await sleep(220);
        for (let n = 1; n <= next.length; n++) {
          setWord(next.slice(0, n));
          await sleep(TYPE_MS);
        }
        caret.classList.remove('typing');
      }
    })();
  }

  // Hero card: hold screen position while the hero scrolls, fade before the seam (spec #4).
  const hero = document.querySelector<HTMLElement>('[data-hero]');
  const card = document.querySelector<HTMLElement>('[data-hero-card]');

  // Desktop-only: on mobile the iOS keyboard's focus-scroll triggers the fade
  // mid-typing and there's no headroom for it anyway (same rule as the pillars'
  // no-pin-on-mobile). Spec row #4.
  const desktop = window.matchMedia('(min-width: 1024px)').matches;

  if (hero && card && desktop && !reduced) {
    // Live rects every frame (no cached offsets): fonts/images/URL-bar
    // resizes can't strand the opacity below 1 on the way back up.
    let ticking = false;
    const update = () => {
      ticking = false;
      const heroRect = hero.getBoundingClientRect();
      const y = Math.max(0, -heroRect.top);
      card.style.transform = `translateY(${y}px)`;
      // Fade normalized to THIS layout's resting distance from the seam —
      // fixed thresholds left mobile permanently under-opaque.
      const restGap = hero.offsetHeight - (card.offsetTop + card.offsetHeight);
      const gapToSeam = heroRect.bottom - card.getBoundingClientRect().bottom;
      const progress = (gapToSeam - 30) / Math.max(1, restGap - 30);
      card.style.opacity = String(Math.min(1, Math.max(0, progress)));
    };
    const queue = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };
    window.addEventListener('scroll', queue, { passive: true });
    window.addEventListener('resize', queue, { passive: true });
  }
</script>
