    {
      cards.map(({ title, body }, i) => (
        <article
          class="flex min-h-[444px] min-w-0 flex-1 flex-col items-center justify-between gap-6 rounded-card bg-bone px-10 py-[30px]"
          data-reveal
        >
          <h3 class="self-stretch text-center font-display text-[19px] leading-[120%] tracking-[-0.01em] text-ink">{title}</h3>
          <div class="flex w-full flex-1 items-center justify-center">
