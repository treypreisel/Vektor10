---
// Stakes — canvas-true (#E6DBCB band, flat bone cards, teal blob icons).
// Reveal: cards rise 12px + fade, 90ms stagger, once (animation spec row 7).

const cards = [
  {
    title: 'Shoppers Go Elsewhere',
    body: 'ChatGPT™ recommends competitors while you have no visibility into the lost sale.',
  },
  {
    title: 'Your Product Truth Drifts',
    body: 'Wrong prices, missing details, or reseller links quietly erode trust and margin.',
  },
  {
    title: 'The Edge Compounds',
    body: 'Every month a competitor gains more ground on a shelf that is only getting more crowded.',
  },
];
---

<section id="stakes" class="flex flex-col items-center gap-[5px] bg-bone-deep px-6 pb-32 pt-[104px] sm:px-[60px]">
