---
// FAQ — the AEO asset. Questions verbatim from the canvas; accordion per
// spec #9 (250ms height, +/− crossfade). First row (ROI) ships open.

const items = [
  {
    q: 'When someone asks AI what to buy in your category, are your products there?',
    a: "Anyone selling you a rank in ChatGPT™ is guessing. AI gives a different answer every time you ask. A single prompt tells you nothing. Ten prompts probably don't either. We run hundreds of real shopper queries across your category topics, again and again, and measure how often your products actually make the shelf. That volume is what turns noise into signal — statistically meaningful patterns across topics, query types, and time that show you where you're winning, where you're absent, and where the gaps are. We show you every result.",
    open: true,
  },
  {
    q: 'What does success look like?',
    a: "We set this on day one so there are no surprises. The KPIs we track: share of voice in your category (how often your brand shows up vs. competitors), number of SKUs being captured in AI conversations, click-throughs to your owned properties — PDPs, category pages, your DTC site — and price and feed accuracy across your catalog. These move on a weekly and monthly cadence. Some improve in weeks, some take longer. We show you the scoreboard every step of the way.",
    open: true,
  },
  {
    q: "Isn't this just another AI SEO or GEO agency?",
    a: "No. The GEO crowd came from blog SEO and sells \"get your brand cited.\" We're a commerce agency — feeds, prices, product data, the digital shelf — getting your actual products bought. We work at the catalog and SKU level, not the blog post level. And we do the work. We're not a dashboard you have to run yourself.",
  },
  {
    q: 'Will this work for my category?',
    a: "We focus on consumer products — beauty, skincare, supplements, home, kitchen, electronics, outdoor, pet, fitness. If you're a brand that wants to take control of its integrity on AI shopping surfaces in a non-restricted category, this is built for you.",
  },
  {
    q: "Why ChatGPT™ only? What about Perplexity or Google's AI?",
    a: "ChatGPT™ has over 900 million weekly active users and roughly 57% of consumer AI traffic. About 1 in 5 conversations show shopping or search intent. That's where the volume is. A clean, correct catalog on ChatGPT™ carries over to Perplexity, Google AI, and the rest — but we'd rather go deep on the surface that's driving the most commerce today than go shallow on all of them.",
  },
  {
    q: 'We already have an AI tracking tool.',
    a: "Good — keep it. Most AI visibility tools track brand mentions. We track at the catalog and SKU level: which products show up, at what price, from which retailer, in which position. And then we fix what's broken. Tools tell you where you're losing. We're the team that does something about it.",
  },
];
---

{/* The AEO asset, machine-readable: these literal Q&As are what ChatGPT™ cites. */}
<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: items.map(({ q, a }) => ({
      '@type': 'Question',
      name: q,
      acceptedAnswer: { '@type': 'Answer', text: a },
    })),
  })}
/>

<section id="faq" class="flex flex-col items-center bg-bone px-6 pb-[150px] pt-[40px] sm:px-[60px]">
  <div class="flex w-full max-w-[1000px] flex-col gap-10 sm:gap-14">
    <div class="flex flex-col gap-[5px]">
      <p class="eyebrow text-teal">&lt; FAIR QUESTIONS &gt;</p>
      <h2 class="font-display text-[24px] leading-[108%] tracking-[-0.02em] text-ink sm:text-headline">
        Straight answers.
      </h2>
    </div>

    <div class="flex flex-col">
      {
        items.map(({ q, a, open }, i) => (
          <div class:list={['faq-item', i > 0 && 'border-t border-bone-muted']} data-faq-item data-open={open ? 'true' : null}>
            <h3>
              <button
                type="button"
                class="flex w-full items-center justify-between gap-6 py-7 text-left sm:gap-10 sm:py-8"
                aria-expanded={open ? 'true' : 'false'}
                data-faq-button
              >
                <span class="font-display text-[20px] leading-[115%] tracking-[-0.02em] text-ink sm:text-title sm:leading-[110%]">{q}</span>
                <span class="relative size-[30px] shrink-0" aria-hidden="true">
                  <span class="faq-plus absolute inset-0 font-mono text-[30px] font-medium leading-[30px] text-teal">+</span>
                  <span class="faq-minus absolute inset-0 font-mono text-[30px] font-medium leading-[30px] text-teal">−</span>
                </span>
              </button>
            </h3>
            <div class="faq-panel grid" data-faq-panel>
              <div class="overflow-hidden">
                <p class="max-w-[760px] pb-8 font-mono text-body font-medium leading-6 text-ink/65 sm:pb-9">{a}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Height animation via grid rows — no measuring, no layout thrash (spec #9). */
  .faq-panel {
    grid-template-rows: 0fr;
    transition: grid-template-rows 250ms var(--ease-out-quart);
  }
  [data-faq-item][data-open] .faq-panel {
    grid-template-rows: 1fr;
  }
  .faq-plus,
  .faq-minus {
    transition: opacity 150ms var(--ease-out-quart);
  }
  [data-faq-item][data-open] .faq-plus {
    opacity: 0;
  }
  [data-faq-item]:not([data-open]) .faq-minus {
    opacity: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .faq-panel,
    .faq-plus,
    .faq-minus {
      transition: none;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-faq-item]').forEach((item) => {
    const button = item.querySelector<HTMLButtonElement>('[data-faq-button]');
    button?.addEventListener('click', () => {
      const open = item.hasAttribute('data-open');
      if (open) {
        item.removeAttribute('data-open');
      } else {
        item.setAttribute('data-open', 'true');
      }
      button.setAttribute('aria-expanded', String(!open));
    });
  });
</script>
