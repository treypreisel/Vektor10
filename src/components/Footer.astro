---
// Green footer, canvas-true: giant V10 mark (V bone, 10 bone-deep), three link
// columns (Cal Sans headers, underlined bone-deep links), legal bar.
// THE FOOTER RULE: every page renders a dither band directly above this.

const columns = [
  {
    header: 'Network',
    links: [
      { label: 'VantaFive', href: 'https://vantafive.com' },
      { label: 'Influent', href: 'https://influent.co' },
      { label: 'Sohva', href: 'https://sohvasocial.com' },
      { label: 'Recho', href: 'https://recho.co' },
    ],
  },
  {
    header: 'Pages',
    links: [
      { label: 'Services', href: '/services' },
      { label: 'Technology', href: '/technology' },
      { label: 'About', href: '/about' },
      { label: 'Book', href: '/book' },
      { label: 'Blog', href: '/blog' },
    ],
  },
  {
    header: 'Connect',
    links: [
      { label: 'Todd@Vektor10.com', href: 'mailto:todd@vektor10.com' },
      { label: 'LinkedIn', href: 'https://www.linkedin.com/in/toddpie/' },
    ],
  },
];
---

<div aria-hidden="true" class="block w-full bg-bone">
  <img src="/dither-bone-green.png" alt="" class="block h-auto w-full" loading="lazy" decoding="async" />
</div>

<footer class="bg-teal px-6 pb-6 pt-4 sm:px-10">
  <div class="mx-auto flex max-w-[1320px] flex-col gap-14">
    <div class="flex flex-col items-start justify-between gap-12 lg:flex-row lg:items-center lg:gap-20">
      <svg
        viewBox="0 0 194 93"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        class="h-auto w-[240px] shrink-0 sm:w-[363px]"
        aria-label="V10"
        role="img"
      >
        <path
          d="M0 0H18.6H21.8032H40.92V18.6C33.48 18.6 29.5941 21.39 29.5941 21.39L43.3372 59.1214C44.7728 63.0186 45.8943 66.9157 46.7019 70.8128C47.1505 68.8643 47.644 66.9157 48.1823 64.9672C48.7207 62.93 49.3487 60.9814 50.0666 59.1214L63.8096 21.39C63.8096 21.39 59.985 18.6 52.545 18.6V0H71.6006H73.005H93L55.7192 93H37.5499L0 0Z"
          fill="#F0EEE5"></path>
        <path d="M98 17L98 80H93V93H98H118H123V80H118L118 0H98.9999L93 15V17H98Z" fill="#E6DBCB"></path>
        <path
          fill-rule="evenodd"
          clip-rule="evenodd"
          d="M176 46.5C176 42.2318 175.814 37.1769 175.522 31.9209L175.516 31.8458C175.514 31.8178 175.511 31.7855 175.508 31.7484C175.506 31.724 175.504 31.6976 175.501 31.6689C175.403 30.5712 175.15 29.4851 174.765 28.4336L156.295 74.6106C157.165 74.8307 158.051 74.9615 158.938 74.9912C159.148 74.9982 159.234 75 160 75C160.766 75 160.852 74.9982 161.062 74.9912C168.035 74.7579 174.882 68.281 175.501 61.3311C175.512 61.2081 175.519 61.1268 175.523 61.0732C175.814 55.8195 176 50.7665 176 46.5ZM145.235 64.5664C144.85 63.5149 144.597 62.4288 144.499 61.3311L144.477 61.0732C144.186 55.8195 144 50.7665 144 46.5C144 42.2318 144.185 37.1768 144.477 31.9209L144.485 31.8273L144.499 31.6689C145.118 24.719 151.965 18.2419 158.938 18.0088C159.148 18.0018 159.234 18 160 18C160.766 18 160.852 18.0018 161.062 18.0088C161.949 18.0385 162.835 18.1692 163.705 18.3893L145.235 64.5664ZM160.52 92.9999L160 93C159.259 93 158.888 92.9999 158.337 92.9814C142.527 92.4528 128.443 79.3529 126.646 63.6758L126.57 62.9277C126.558 62.7863 126.548 62.675 126.54 62.5848C126.533 62.4999 126.528 62.4335 126.523 62.3779L126.506 62.1035C126.204 56.666 126 51.2368 126 46.5C126 42.3553 126.156 37.681 126.397 32.9346L126.506 30.8965L126.513 30.7764L126.518 30.7018L126.523 30.6221L126.57 30.0723C127.974 14.3158 141.833 0.977661 157.586 0.0527344L158.337 0.0185547C158.888 0.00012207 159.259 0 160 0C160.741 0 161.112 0.00012207 161.663 0.0185547C177.724 0.555664 192.004 14.0659 193.43 30.0723C193.479 30.621 193.484 30.7133 193.494 30.8965C193.796 36.334 194 41.7632 194 46.5C194 51.2368 193.796 56.666 193.494 62.1035L193.477 62.3779C193.472 62.4337 193.467 62.5005 193.46 62.5862C193.452 62.6761 193.442 62.787 193.43 62.9277L193.354 63.6758C191.557 79.3529 177.473 92.4528 161.663 92.9814L160.902 92.998C160.783 92.9991 160.658 92.9996 160.52 92.9999Z"
          fill="#E6DBCB"></path>
      </svg>

      <div class="flex flex-wrap gap-x-[90px] gap-y-10">
        {
          columns.map(({ header, links }) => (
            <div class="flex flex-col gap-[18px]">
              <span class="font-display text-title leading-none text-bone">{header.toUpperCase()}</span>
              {links.map(({ label, href }) => (
                <a
                  href={href}
                  target={href.startsWith('http') ? '_blank' : undefined}
                  rel={href.startsWith('http') ? 'noopener' : undefined}
                  class="font-mono text-body font-medium leading-[18px] text-bone-deep underline decoration-1 underline-offset-[3px] transition-colors duration-150 ease-out-quart hover:text-bone"
                >
                  {label}
                </a>
              ))}
            </div>
          ))
        }
      </div>
    </div>

    <div class="flex flex-col gap-4 border-t border-ink/25 pt-7 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex flex-col gap-1.5">
        <p class="font-mono text-body font-medium text-bone-muted">© 2026 Vektor10, Inc. · A VantaFive Agency</p>
        <p class="font-mono text-body font-medium text-bone-muted">
          ChatGPT is a trademark of <a
            href="https://openai.com"
            target="_blank"
            rel="noopener"
            class="underline decoration-1 underline-offset-[3px] transition-colors duration-150 hover:text-bone">OpenAI</a
          >. Vektor10 is an independent agency, not affiliated with or endorsed by OpenAI.
        </p>
      </div>
      <div class="flex gap-8">
        <a href="/privacy" class="font-mono text-body font-medium text-bone transition-colors duration-150 hover:underline">Privacy</a>
        <a href="/terms" class="font-mono text-body font-medium text-bone transition-colors duration-150 hover:underline">Terms</a>
      </div>
    </div>
  </div>
</footer>
