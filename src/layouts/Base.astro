---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import '@fontsource/cal-sans/400.css';
import '@fontsource/geist-mono/500.css';
import '@fontsource/geist-mono/600.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Tints iOS Safari's status-bar area; pages with photo heroes pass their sky color. */
  themeColor?: string;
  /** Document canvas background — iOS paints the status-bar strip and overscroll with this.
      Two-tone gradients let top overscroll match the hero and bottom match the footer. */
  rootBackground?: string;
  /** Social share image (absolute path); pages with their own imagery pass it. */
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description = 'Vektor10 — The 1st Full-Suite ChatGPT Commerce Agency.',
  themeColor = '#F0EEE5',
  rootBackground = '#F0EEE5',
  ogImage = '/og-default.jpg',
  ogType = 'website',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageAbs = new URL(ogImage, Astro.site);
const GA4_ID = import.meta.env.PUBLIC_GA4_ID;
---

<!doctype html>
<html lang="en" style={`background: ${rootBackground};`}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <script is:inline>
      // iOS auto-zooms inputs with sub-16px text (our 10px functional-button
      // role). maximum-scale=1 suppresses ONLY the auto-zoom on iOS — pinch
      // zoom still works there — but would block pinch on Android, so apply
      // it to iOS devices only. (Standard documented workaround.)
      if (/iPhone|iPad|iPod/.test(navigator.userAgent)) {
        const vp = document.querySelector('meta[name="viewport"]');
        if (vp) vp.setAttribute('content', vp.getAttribute('content') + ', maximum-scale=1');
      }
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content={themeColor} />
    <!-- SVG favicon carries its own light/dark media query; PNG is the fallback. -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Vektor10" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: 'Vektor10, Inc.',
        url: 'https://vektor10.com',
        description: 'The 1st full-suite ChatGPT commerce agency. Vektor10 gets consumer brands found, recommended, and bought in ChatGPT.',
        email: 'todd@vektor10.com',
        founder: { '@type': 'Person', name: 'Todd Piechowski' },
        parentOrganization: { '@type': 'Organization', name: 'VantaFive' },
        sameAs: ['https://www.linkedin.com/in/toddpie/'],
      })}
    />

    <Analytics />
    <SpeedInsights />
    {
      GA4_ID && (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`} is:inline />
          <script
            is:inline
            set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)};gtag('js',new Date());gtag('config','${GA4_ID}');`}
          />
        </>
      )
    }
  </head>
  <body class="min-h-screen bg-bone font-mono text-ink">
    <slot />
    <script>
      // Shared scroll reveal for every [data-stagger] group (spec row 7).
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduced && 'IntersectionObserver' in window) {
        document.querySelectorAll<HTMLElement>('[data-stagger]').forEach((group) => {
          const items = [...group.querySelectorAll<HTMLElement>('[data-reveal]')];
          items.forEach((el, i) => {
            el.classList.add('pre');
            el.style.setProperty('--reveal-delay', `${i * 90}ms`);
          });
          const reveal = () => items.forEach((el) => el.classList.remove('pre'));
          const io = new IntersectionObserver(
            (entries) => {
              for (const e of entries) {
                if (e.isIntersecting) {
                  reveal();
                  io.disconnect();
                }
              }
            },
            { threshold: 0.15 }
          );
          io.observe(group);
          // Failsafe: headless renderers, crawlers, and stitched screenshots
          // never scroll — content must not stay hidden behind the reveal.
          setTimeout(reveal, 3000);
        });
      }
    </script>
  </body>
</html>
