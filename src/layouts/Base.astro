---
import '@fontsource/cal-sans/400.css';
import '@fontsource/geist-mono/500.css';
import '@fontsource/geist-mono/600.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Tints iOS Safari's status-bar area; pages with photo heroes pass their sky color. */
  themeColor?: string;
  /** Document canvas background — iOS paints the status-bar strip and overscroll with this.
      Two-tone gradients let top overscroll match the hero and bottom match the footer. */
  rootBackground?: string;
}

const {
  title,
  description = 'Vektor10 — The 1st Full-Suite ChatGPT Commerce Agency.',
  themeColor = '#F0EEE5',
  rootBackground = '#F0EEE5',
} = Astro.props;
---

<!doctype html>
<html lang="en" style={`background: ${rootBackground};`}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <script is:inline>
      // iOS auto-zooms inputs with sub-16px text (our 10px functional-button
      // role). maximum-scale=1 suppresses ONLY the auto-zoom on iOS — pinch
      // zoom still works there — but would block pinch on Android, so apply
      // it to iOS devices only. (Standard documented workaround.)
      if (/iPhone|iPad|iPod/.test(navigator.userAgent)) {
        const vp = document.querySelector('meta[name="viewport"]');
        if (vp) vp.setAttribute('content', vp.getAttribute('content') + ', maximum-scale=1');
      }
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content={themeColor} />
    <meta name="robots" content="noindex, nofollow" />
    <!-- noindex stays until the production domain cutover -->
  </head>
  <body class="min-h-screen bg-bone font-mono text-ink">
    <slot />
  </body>
</html>
