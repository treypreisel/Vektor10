---
import '@fontsource/cal-sans/400.css';
import '@fontsource/geist-mono/500.css';
import '@fontsource/geist-mono/600.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Vektor10 — The First Full-Suite ChatGPT™ Commerce Agency.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <!-- noindex stays until the production domain cutover -->
  </head>
  <body class="min-h-screen bg-bone font-mono text-ink">
    <slot />
  </body>
</html>
